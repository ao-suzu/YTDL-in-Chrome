<?xml version="1.0" encoding="UTF-8"?>
<Wix xmlns="http://wixtoolset.org/schemas/v4/wxs">

  <!-- ============================================================ -->
  <!--  Custom UI: Extension ID Input Dialog                        -->
  <!--  Inserts a custom dialog into the WixUI_InstallDir flow      -->
  <!--  to collect the Chrome Extension ID from the user.           -->
  <!-- ============================================================ -->

  <Fragment>
    <UI Id="WixUI_ExtensionId">

      <!-- Reference the built-in dialogs we need -->
      <DialogRef Id="WelcomeDlg" />
      <DialogRef Id="InstallDirDlg" />
      <DialogRef Id="VerifyReadyDlg" />
      <DialogRef Id="DiskCostDlg" />
      <DialogRef Id="ErrorDlg" />
      <DialogRef Id="FatalError" />
      <DialogRef Id="FilesInUse" />
      <DialogRef Id="UserExit" />
      <DialogRef Id="ExitDialog" />
      <DialogRef Id="ProgressDlg" />

      <!-- ========== Extension ID Dialog ========== -->
      <Dialog Id="ExtensionIdDlg" Width="370" Height="270"
              Title="!(loc.InstallDirDlg_Title)">

        <!-- Title banner -->
        <Control Id="BannerBitmap" Type="Bitmap" X="0" Y="0" Width="370" Height="44"
                 TabSkip="no" Text="!(loc.InstallDirDlgBannerBitmap)" />
        <Control Id="BannerLine" Type="Line" X="0" Y="44" Width="370" Height="0" />

        <!-- Bottom line -->
        <Control Id="BottomLine" Type="Line" X="0" Y="234" Width="370" Height="0" />

        <!-- Header text -->
        <Control Id="Title" Type="Text" X="15" Y="6" Width="200" Height="15" Transparent="yes"
                 NoPrefix="yes" Text="{\WixUI_Font_Title}拡張機能IDの設定" />
        <Control Id="Description" Type="Text" X="25" Y="23" Width="280" Height="15"
                 Transparent="yes" NoPrefix="yes"
                 Text="ブラウザの拡張機能IDを入力してください。" />

        <!-- Instructions -->
        <Control Id="Instruction1" Type="Text" X="20" Y="60" Width="330" Height="15"
                 NoPrefix="yes" Text="1. ブラウザで chrome://extensions/ を開く" />
        <Control Id="Instruction2" Type="Text" X="20" Y="75" Width="330" Height="15"
                 NoPrefix="yes" Text="2. デベロッパーモードをONにする" />
        <Control Id="Instruction3" Type="Text" X="20" Y="90" Width="330" Height="15"
                 NoPrefix="yes" Text='3. 「YT Downloader」のIDをコピー（32文字の英小文字）' />

        <!-- Extension ID Label -->
        <Control Id="ExtIdLabel" Type="Text" X="20" Y="120" Width="120" Height="15"
                 NoPrefix="yes" Text="拡張機能ID:" />

        <!-- Extension ID Input -->
        <Control Id="ExtIdEdit" Type="Edit" X="20" Y="136" Width="260" Height="18"
                 Property="EXTENSION_ID" />

        <!-- Hint -->
        <Control Id="ExtIdHint" Type="Text" X="20" Y="160" Width="330" Height="15"
                 NoPrefix="yes" Text="※ 例: abcdefghijklmnopqrstuvwxyz123456" />

        <!-- Validation warning -->
        <Control Id="ExtIdWarning" Type="Text" X="20" Y="180" Width="330" Height="30"
                 NoPrefix="yes" Text="※ IDが空の場合、後から手動でsetup_host.ps1を実行して設定できます。" />

        <!-- Buttons -->
        <Control Id="Back" Type="PushButton" X="180" Y="243" Width="56" Height="17"
                 Text="!(loc.WixUIBack)">
          <Publish Event="NewDialog" Value="InstallDirDlg" />
        </Control>

        <Control Id="Next" Type="PushButton" X="236" Y="243" Width="56" Height="17"
                 Default="yes" Text="!(loc.WixUINext)">
          <Publish Event="NewDialog" Value="VerifyReadyDlg" />
        </Control>

        <Control Id="Cancel" Type="PushButton" X="304" Y="243" Width="56" Height="17"
                 Cancel="yes" Text="!(loc.WixUICancel)">
          <Publish Event="SpawnDialog" Value="CancelDlg" />
        </Control>
      </Dialog>

      <!-- ========== Dialog Flow ========== -->
      <!-- Welcome → InstallDir → ExtensionId → VerifyReady → Progress → Exit -->

      <!-- WelcomeDlg Next → InstallDirDlg -->
      <Publish Dialog="WelcomeDlg" Control="Next" Event="NewDialog" Value="InstallDirDlg" />

      <!-- InstallDirDlg Back → WelcomeDlg -->
      <Publish Dialog="InstallDirDlg" Control="Back" Event="NewDialog" Value="WelcomeDlg" />

      <!-- InstallDirDlg Next → ExtensionIdDlg -->
      <Publish Dialog="InstallDirDlg" Control="Next" Event="NewDialog" Value="ExtensionIdDlg" />
      <Publish Dialog="InstallDirDlg" Control="Next" Event="SetTargetPath" Value="[WIXUI_INSTALLDIR]" Order="1" />

      <!-- InstallDirDlg ChangeFolder -->
      <Publish Dialog="InstallDirDlg" Control="ChangeFolder" Property="_BrowseProperty" Value="[WIXUI_INSTALLDIR]" Order="1" />
      <Publish Dialog="InstallDirDlg" Control="ChangeFolder" Event="SpawnDialog" Value="BrowseDlg" Order="2" />

      <!-- VerifyReadyDlg Back → ExtensionIdDlg -->
      <Publish Dialog="VerifyReadyDlg" Control="Back" Event="NewDialog" Value="ExtensionIdDlg" Condition="NOT Installed" />
      <Publish Dialog="VerifyReadyDlg" Control="Back" Event="NewDialog" Value="WelcomeDlg" Condition="Installed AND NOT PATCH" />

      <!-- Exit Dialog -->
      <Publish Dialog="ExitDialog" Control="Finish" Event="EndDialog" Value="Return" />

      <!-- Set WIXUI_INSTALLDIR -->
      <Property Id="WIXUI_INSTALLDIR" Value="INSTALLFOLDER" />

    </UI>

    <UIRef Id="WixUI_Common" />
  </Fragment>
</Wix>
